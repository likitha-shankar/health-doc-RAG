# Copy this file to secrets.toml and fill in your values.
# On Streamlit Cloud, set these in the app's Secrets settings instead.

# Groq (free, fast) — https://console.groq.com/keys
LLM_BASE_URL = "https://api.groq.com/openai/v1"
LLM_API_KEY = "gsk_your_groq_api_key_here"
LLM_MODEL = "llama-3.3-70b-versatile"

# Other compatible providers:
# Together AI: LLM_BASE_URL = "https://api.together.xyz/v1"
# OpenRouter:  LLM_BASE_URL = "https://openrouter.ai/api/v1"
# OpenAI:      LLM_BASE_URL = "https://api.openai.com/v1"
